{
  "wandb": {
    "project": "dialect-grpo-v2",
    "entity": "jordanpainter",
    "api_key": "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"
  },

  "model": {
    "model_id": "jordanpainter/gemma3-sft-dialect",
    "tokenizer_id": "google/gemma-3-4b-it",

    "load_in_4bit": false,
    "bnb_4bit_compute_dtype": "bfloat16",
    "bnb_4bit_quant_type": "nf4",
    "bnb_4bit_use_double_quant": true
  },

  "peft": {
    "enabled": false,
    "r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "target_modules": [
      "q_proj", "k_proj", "v_proj", "o_proj",
      "gate_proj", "up_proj", "down_proj"
    ],
    "bias": "none",
    "task_type": "CAUSAL_LM"
  },

  "data": {
    "dataset_id": "jordanpainter/dialect-preferences-with-base-gemma",
    "dataset_split": "train",
    "base_output_column": "base_output_gemma",
    "seed": 42,
    "test_size": 0.02,
    "system_prompt": "You are a helpful assistant."
  },

  "rewards": {
    "weights": {
      "dialect": 0.5,
      "comet": 0.25,
      "cosine": 0.25
    },

    "normalization": {
      "method": "running_zscore",
      "clip_z": 5.0,
      "eps": 1e-6,
      "beta": 0.99,
      "warmup_steps": 50
    },

    "comet_model_name": "Unbabel/wmt22-comet-da",
    "comet_batch_size": 2,
    "comet_force_cpu": false,

    "sim_model_name": "sentence-transformers/all-MiniLM-L6-v2",
    "verbose_examples": 2
  },

  "trainer": {
    "ddp_find_unused_parameters": false,
    "length_safety_margin": 16,

    "output_dir": "/mnt/fast/nobackup/scratch4weeks/jp01166/runs/grpo_gemma_50",
    "report_to": "wandb",

    "max_steps": 5000,
    "learning_rate": 5e-6,
    "warmup_ratio": 0.05,
    "weight_decay": 0.0,

    "bf16": true,
    "fp16": false,
    "gradient_checkpointing": true,

    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 4,

    "logging_steps": 1,

    "max_completion_length": 256,

    "num_generations": 4,
    "temperature": 0.7,
    "top_p": 0.95,

    "generation_kwargs": {
      "do_sample": true
    },

    "beta": 0.0,
    "scale_rewards": false
  }
}
